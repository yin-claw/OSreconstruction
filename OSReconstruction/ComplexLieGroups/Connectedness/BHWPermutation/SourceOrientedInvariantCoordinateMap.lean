import OSReconstruction.ComplexLieGroups.Connectedness.BHWPermutation.SourceOrientedInvariantCoordinateTransport

/-!
# Generator coordinate maps for the oriented invariant-theory packet

This file defines the coordinate maps onto the subalgebras generated by the
displayed pairing/volume and source Gram/determinant polynomials.  It proves
the formal surjectivity and source/dot transport of these generator
presentations.  It does not assert that these generated subalgebras are the
full invariant subalgebras; that is the genuine standard `SO` FFT input.
-/

noncomputable section

open Complex Topology Matrix LorentzLieGroup Classical Filter NormedSpace

namespace BHW

/-- The standard-dot subalgebra generated by pairings and ordered volumes. -/
def standardSOGeneratorSubalgebra
    (D n : ℕ) : Subalgebra ℂ (standardTupleCoordinateRing D n) :=
  Algebra.adjoin ℂ
    (Set.range (standardPairingCoordinatePolynomial D n) ∪
      Set.range (standardVolumeCoordinatePolynomial D n))

/-- The source subalgebra generated by Gram entries and selected full-frame
determinants. -/
def sourceOrientedGeneratorSubalgebra
    (d n : ℕ) : Subalgebra ℂ (sourceTupleCoordinateRing d n) :=
  Algebra.adjoin ℂ
    (Set.range (sourceGramCoordinatePolynomial d n) ∪
      Set.range (sourceFullFrameDetPolynomial d n))

theorem standardPairingCoordinatePolynomial_mem_generatorSubalgebra
    (D n : ℕ) (ij : Fin n × Fin n) :
    standardPairingCoordinatePolynomial D n ij ∈
      standardSOGeneratorSubalgebra D n := by
  exact Algebra.subset_adjoin (Or.inl ⟨ij, rfl⟩)

theorem standardVolumeCoordinatePolynomial_mem_generatorSubalgebra
    (D n : ℕ) (ι : Fin D ↪ Fin n) :
    standardVolumeCoordinatePolynomial D n ι ∈
      standardSOGeneratorSubalgebra D n := by
  exact Algebra.subset_adjoin (Or.inr ⟨ι, rfl⟩)

theorem sourceGramCoordinatePolynomial_mem_generatorSubalgebra
    (d n : ℕ) (ij : Fin n × Fin n) :
    sourceGramCoordinatePolynomial d n ij ∈
      sourceOrientedGeneratorSubalgebra d n := by
  exact Algebra.subset_adjoin (Or.inl ⟨ij, rfl⟩)

theorem sourceFullFrameDetPolynomial_mem_generatorSubalgebra
    (d n : ℕ) (ι : Fin (d + 1) ↪ Fin n) :
    sourceFullFrameDetPolynomial d n ι ∈
      sourceOrientedGeneratorSubalgebra d n := by
  exact Algebra.subset_adjoin (Or.inr ⟨ι, rfl⟩)

/-- Pairing polynomial as an element of the generated standard-dot
subalgebra. -/
def standardPairingGeneratorElement
    (D n : ℕ) (ij : Fin n × Fin n) :
    standardSOGeneratorSubalgebra D n :=
  ⟨standardPairingCoordinatePolynomial D n ij,
    standardPairingCoordinatePolynomial_mem_generatorSubalgebra D n ij⟩

/-- Ordered volume polynomial as an element of the generated standard-dot
subalgebra. -/
def standardVolumeGeneratorElement
    (D n : ℕ) (ι : Fin D ↪ Fin n) :
    standardSOGeneratorSubalgebra D n :=
  ⟨standardVolumeCoordinatePolynomial D n ι,
    standardVolumeCoordinatePolynomial_mem_generatorSubalgebra D n ι⟩

/-- Source Gram polynomial as an element of the generated source subalgebra. -/
def sourceGramGeneratorElement
    (d n : ℕ) (ij : Fin n × Fin n) :
    sourceOrientedGeneratorSubalgebra d n :=
  ⟨sourceGramCoordinatePolynomial d n ij,
    sourceGramCoordinatePolynomial_mem_generatorSubalgebra d n ij⟩

/-- Source selected full-frame determinant polynomial as an element of the
generated source subalgebra. -/
def sourceFullFrameDetGeneratorElement
    (d n : ℕ) (ι : Fin (d + 1) ↪ Fin n) :
    sourceOrientedGeneratorSubalgebra d n :=
  ⟨sourceFullFrameDetPolynomial d n ι,
    sourceFullFrameDetPolynomial_mem_generatorSubalgebra d n ι⟩

/-- Coordinate map from the standard pairing/volume presentation onto its
generated subalgebra. -/
def standardSOGeneratorCoordinateMap
    (D n : ℕ) :
    standardSOInvariantCoordinateRing D n →ₐ[ℂ]
      standardSOGeneratorSubalgebra D n :=
  MvPolynomial.aeval
    (fun x =>
      match x with
      | Sum.inl ij => standardPairingGeneratorElement D n ij
      | Sum.inr ι => standardVolumeGeneratorElement D n ι)

/-- Coordinate map from the source Gram/determinant presentation onto its
generated subalgebra. -/
def sourceOrientedGeneratorCoordinateMap
    (d n : ℕ) :
    sourceOrientedInvariantCoordinateRing d n →ₐ[ℂ]
      sourceOrientedGeneratorSubalgebra d n :=
  MvPolynomial.aeval
    (fun x =>
      match x with
      | Sum.inl ij => sourceGramGeneratorElement d n ij
      | Sum.inr ι => sourceFullFrameDetGeneratorElement d n ι)

@[simp]
theorem standardSOGeneratorCoordinateMap_apply_pairing
    (D n : ℕ) (ij : Fin n × Fin n) :
    standardSOGeneratorCoordinateMap D n (MvPolynomial.X (Sum.inl ij)) =
      standardPairingGeneratorElement D n ij := by
  simp [standardSOGeneratorCoordinateMap]

@[simp]
theorem standardSOGeneratorCoordinateMap_apply_volume
    (D n : ℕ) (ι : Fin D ↪ Fin n) :
    standardSOGeneratorCoordinateMap D n (MvPolynomial.X (Sum.inr ι)) =
      standardVolumeGeneratorElement D n ι := by
  simp [standardSOGeneratorCoordinateMap]

@[simp]
theorem sourceOrientedGeneratorCoordinateMap_apply_gram
    (d n : ℕ) (ij : Fin n × Fin n) :
    sourceOrientedGeneratorCoordinateMap d n (MvPolynomial.X (Sum.inl ij)) =
      sourceGramGeneratorElement d n ij := by
  simp [sourceOrientedGeneratorCoordinateMap]

@[simp]
theorem sourceOrientedGeneratorCoordinateMap_apply_det
    (d n : ℕ) (ι : Fin (d + 1) ↪ Fin n) :
    sourceOrientedGeneratorCoordinateMap d n (MvPolynomial.X (Sum.inr ι)) =
      sourceFullFrameDetGeneratorElement d n ι := by
  simp [sourceOrientedGeneratorCoordinateMap]

/-- The standard-dot generator coordinate map is surjective onto the
subalgebra it generates. -/
theorem standardSOGeneratorCoordinateMap_surjective
    (D n : ℕ) :
    Function.Surjective (standardSOGeneratorCoordinateMap D n) := by
  intro y
  change y ∈ (standardSOGeneratorCoordinateMap D n).range
  let U : Set (standardTupleCoordinateRing D n) :=
    Set.range (standardPairingCoordinatePolynomial D n) ∪
      Set.range (standardVolumeCoordinatePolynomial D n)
  have hy : (y : standardTupleCoordinateRing D n) ∈
      Algebra.adjoin ℂ U := y.2
  refine Algebra.adjoin_induction
    (s := U)
    (p := fun x hx =>
      (⟨x, hx⟩ : standardSOGeneratorSubalgebra D n) ∈
        (standardSOGeneratorCoordinateMap D n).range)
    ?mem ?alg ?add ?mul hy
  · intro x hx
    rcases hx with hx | hx
    · rcases hx with ⟨ij, rfl⟩
      refine ⟨MvPolynomial.X (Sum.inl ij), ?_⟩
      ext
      simp [standardPairingGeneratorElement]
    · rcases hx with ⟨ι, rfl⟩
      refine ⟨MvPolynomial.X (Sum.inr ι), ?_⟩
      ext
      simp [standardVolumeGeneratorElement]
  · intro r
    exact
      ⟨MvPolynomial.C r, by
        ext
        simp [standardSOGeneratorCoordinateMap]⟩
  · intro _x _z _hx _hz hxmem hzmem
    simpa using
      ((standardSOGeneratorCoordinateMap D n).range.add_mem hxmem hzmem)
  · intro _x _z _hx _hz hxmem hzmem
    simpa using
      ((standardSOGeneratorCoordinateMap D n).range.mul_mem hxmem hzmem)

theorem standardSOGeneratorCoordinateMap_range_eq_top
    (D n : ℕ) :
    (standardSOGeneratorCoordinateMap D n).range = ⊤ := by
  exact (AlgHom.range_eq_top (standardSOGeneratorCoordinateMap D n)).2
    (standardSOGeneratorCoordinateMap_surjective D n)

/-- The source generator coordinate map is surjective onto the subalgebra it
generates. -/
theorem sourceOrientedGeneratorCoordinateMap_surjective
    (d n : ℕ) :
    Function.Surjective (sourceOrientedGeneratorCoordinateMap d n) := by
  intro y
  change y ∈ (sourceOrientedGeneratorCoordinateMap d n).range
  let U : Set (sourceTupleCoordinateRing d n) :=
    Set.range (sourceGramCoordinatePolynomial d n) ∪
      Set.range (sourceFullFrameDetPolynomial d n)
  have hy : (y : sourceTupleCoordinateRing d n) ∈
      Algebra.adjoin ℂ U := y.2
  refine Algebra.adjoin_induction
    (s := U)
    (p := fun x hx =>
      (⟨x, hx⟩ : sourceOrientedGeneratorSubalgebra d n) ∈
        (sourceOrientedGeneratorCoordinateMap d n).range)
    ?mem ?alg ?add ?mul hy
  · intro x hx
    rcases hx with hx | hx
    · rcases hx with ⟨ij, rfl⟩
      refine ⟨MvPolynomial.X (Sum.inl ij), ?_⟩
      ext
      simp [sourceGramGeneratorElement]
    · rcases hx with ⟨ι, rfl⟩
      refine ⟨MvPolynomial.X (Sum.inr ι), ?_⟩
      ext
      simp [sourceFullFrameDetGeneratorElement]
  · intro r
    exact
      ⟨MvPolynomial.C r, by
        ext
        simp [sourceOrientedGeneratorCoordinateMap]⟩
  · intro _x _z _hx _hz hxmem hzmem
    simpa using
      ((sourceOrientedGeneratorCoordinateMap d n).range.add_mem hxmem hzmem)
  · intro _x _z _hx _hz hxmem hzmem
    simpa using
      ((sourceOrientedGeneratorCoordinateMap d n).range.mul_mem hxmem hzmem)

theorem sourceOrientedGeneratorCoordinateMap_range_eq_top
    (d n : ℕ) :
    (sourceOrientedGeneratorCoordinateMap d n).range = ⊤ := by
  exact (AlgHom.range_eq_top (sourceOrientedGeneratorCoordinateMap d n)).2
    (sourceOrientedGeneratorCoordinateMap_surjective d n)

/-- Source-to-dot coordinate transport sends the source generated subalgebra
onto the standard-dot generated subalgebra. -/
theorem sourceMinkowskiToDotCoordinateRingEquiv_map_sourceGeneratorSubalgebra
    (d n : ℕ) :
    algEquivMapSubalgebra
        (sourceMinkowskiToDotCoordinateRingEquiv d n)
        (sourceOrientedGeneratorSubalgebra d n) =
      standardSOGeneratorSubalgebra (d + 1) n := by
  simpa [sourceOrientedGeneratorSubalgebra, standardSOGeneratorSubalgebra] using
    sourceMinkowskiToDotCoordinateRingEquiv_adjoin_pairing_volume d n

/-- The source-to-dot coordinate equivalence restricted to generated
subalgebras. -/
def sourceMinkowskiToDotGeneratorSubalgebraEquiv
    (d n : ℕ) :
    sourceOrientedGeneratorSubalgebra d n ≃ₐ[ℂ]
      standardSOGeneratorSubalgebra (d + 1) n :=
  algEquivOfMappedSubalgebraEq
    (sourceMinkowskiToDotCoordinateRingEquiv d n)
    (sourceOrientedGeneratorSubalgebra d n)
    (standardSOGeneratorSubalgebra (d + 1) n)
    (sourceMinkowskiToDotCoordinateRingEquiv_map_sourceGeneratorSubalgebra d n)

@[simp]
theorem sourceMinkowskiToDotGeneratorSubalgebraEquiv_apply_sourceGram
    (d n : ℕ) (ij : Fin n × Fin n) :
    sourceMinkowskiToDotGeneratorSubalgebraEquiv d n
        (sourceGramGeneratorElement d n ij) =
      standardPairingGeneratorElement (d + 1) n ij := by
  ext
  simp [sourceMinkowskiToDotGeneratorSubalgebraEquiv,
    sourceGramGeneratorElement, standardPairingGeneratorElement,
    algEquivOfMappedSubalgebraEq,
    sourceMinkowskiToDotCoordinateRingEquiv_apply_sourceGram]

@[simp]
theorem sourceMinkowskiToDotGeneratorSubalgebraEquiv_apply_sourceDet
    (d n : ℕ) (ι : Fin (d + 1) ↪ Fin n) :
    sourceMinkowskiToDotGeneratorSubalgebraEquiv d n
        (sourceFullFrameDetGeneratorElement d n ι) =
      (algebraMap ℂ (standardSOGeneratorSubalgebra (d + 1) n)
          (sourceMinkowskiToDotInvDetScale d)) *
        standardVolumeGeneratorElement (d + 1) n ι := by
  ext
  simp [sourceMinkowskiToDotGeneratorSubalgebraEquiv,
    sourceFullFrameDetGeneratorElement, standardVolumeGeneratorElement,
    algEquivOfMappedSubalgebraEq,
    sourceMinkowskiToDotCoordinateRingEquiv_apply_sourceDet]

/-- The source/dot generator-coordinate square commutes. -/
theorem sourceMinkowskiToDotGeneratorCoordinateMap_commutes
    (d n : ℕ)
    (p : sourceOrientedInvariantCoordinateRing d n) :
    sourceMinkowskiToDotGeneratorSubalgebraEquiv d n
        (sourceOrientedGeneratorCoordinateMap d n p) =
      standardSOGeneratorCoordinateMap (d + 1) n
        (sourceMinkowskiToDotInvariantCoordinateEquiv d n p) := by
  induction p using MvPolynomial.induction_on with
  | C _a =>
      ext
      simp [standardSOGeneratorCoordinateMap,
        sourceOrientedGeneratorCoordinateMap,
        sourceMinkowskiToDotInvariantCoordinateEquiv,
        sourceMinkowskiToDotInvariantCoordinateRingHom]
  | add _p _q hp hq =>
      simp [hp, hq]
  | mul_X p a hp =>
      cases a with
      | inl _ij =>
          simp [hp]
      | inr _ι =>
          simp [hp]

end BHW
